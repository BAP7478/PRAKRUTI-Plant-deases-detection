# 🌱 PRAKRUTI Backend Environment Configuration

# Server Settings
PRAKRUTI_HOST=0.0.0.0
PRAKRUTI_PORT=8002
PRAKRUTI_DEBUG=true

# OpenWeatherMap API (FREE - Get key from https://openweathermap.org/api)
# Sign up for free: https://home.openweathermap.org/users/sign_up
# Replace 'demo_key' with your actual free API key
PRAKRUTI_WEATHER_API_KEY=demo_key
PRAKRUTI_WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Logging
PRAKRUTI_LOG_LEVEL=INFO
