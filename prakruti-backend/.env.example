# PRAKRUTI Backend Environment Configuration
# Copy this file to .env and modify as needed

# Server Configuration
PRAKRUTI_HOST=0.0.0.0
PRAKRUTI_PORT=8002
PRAKRUTI_DEBUG=false
PRAKRUTI_RELOAD=true
PRAKRUTI_WORKERS=1

# Security Settings
PRAKRUTI_API_KEY=your_secret_api_key_here
PRAKRUTI_MAX_FILE_SIZE=10485760

# Model Configuration
PRAKRUTI_MODEL_PATH=models/mobilenet_model.tflite
PRAKRUTI_MODEL_WARM_UP=true

# Performance Settings
PRAKRUTI_MAX_CONCURRENT_REQUESTS=10
PRAKRUTI_THREAD_POOL_WORKERS=4
PRAKRUTI_CACHE_TTL=3600
PRAKRUTI_CACHE_SIZE=1000

# Database (Future Use)
# PRAKRUTI_DATABASE_URL=sqlite:///./prakruti.db
# PRAKRUTI_DATABASE_URL=postgresql://user:password@localhost/prakruti

# External APIs - OpenWeatherMap (FREE tier: 1000 calls/day)
# Get your free API key from: https://openweathermap.org/api
PRAKRUTI_WEATHER_API_KEY=your_free_openweather_api_key_here
PRAKRUTI_WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# AI Chatbot APIs (Choose one or both)
# OpenAI GPT API (Paid service - https://platform.openai.com/api-keys)
PRAKRUTI_OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (Free tier available - https://makersuite.google.com/app/apikey)
PRAKRUTI_GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider Selection: "openai", "gemini", or "auto" (tries OpenAI first, then Gemini)
PRAKRUTI_CHATBOT_PROVIDER=auto

# Logging
PRAKRUTI_LOG_LEVEL=INFO
PRAKRUTI_LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# File Paths
PRAKRUTI_REMEDIES_FILE=disease_remedies.json
PRAKRUTI_MODELS_DIR=models
PRAKRUTI_LOGS_DIR=logs

# CORS Settings (comma-separated list)
PRAKRUTI_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080
